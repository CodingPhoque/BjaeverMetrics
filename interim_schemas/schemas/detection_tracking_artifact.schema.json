{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bjaevermetrics:schema:tracking_artifact:1.0",
  "title": "BjaeverMetrics Tracking Intermediate Artifact",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "source_io_artifact",
    "video_id",
    "model",
    "tracker",
    "processing",
    "summary",
    "frames"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "tracking"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "source_io_artifact": {
      "type": "string",
      "minLength": 1
    },
    "video_id": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "object",
      "required": ["name", "weights_path", "classes"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "weights_path": {
          "type": "string",
          "minLength": 1
        },
        "classes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tracker": {
      "type": "object",
      "required": ["name", "config"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "processing": {
      "type": "object",
      "required": ["fps_processed", "frame_stride"],
      "additionalProperties": false,
      "properties": {
        "fps_processed": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "frame_stride": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["frames_processed", "total_objects", "objects_by_class"],
      "additionalProperties": false,
      "properties": {
        "frames_processed": {
          "type": "integer",
          "minimum": 1
        },
        "total_objects": {
          "type": "integer",
          "minimum": 0
        },
        "objects_by_class": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["frame_index", "objects"],
        "additionalProperties": false,
        "properties": {
          "frame_index": {
            "type": "integer",
            "minimum": 0
          },
          "objects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "track_id",
                "class_id",
                "class_name",
                "confidence",
                "bbox_xyxy"
              ],
              "additionalProperties": false,
              "properties": {
                "track_id": {
                  "type": ["integer", "null"],
                  "minimum": 0
                },
                "class_id": {
                  "type": "integer",
                  "minimum": 0
                },
                "class_name": {
                  "type": "string",
                  "enum": ["player", "goalkeeper", "ball", "referee"]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "bbox_xyxy": {
                  "type": "array",
                  "minItems": 4,
                  "maxItems": 4,
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}